# ================================
# Database
# ================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=insurance_v2
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DB_SSL_MODE=prefer

# ================================
# JWT
# ================================
JWT_SECRET_KEY=change-this-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ================================
# CORS (comma-separated origins)
# ================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ================================
# Redis
# ================================
REDIS_HOST=localhost
REDIS_KEY=defaultkey

# ================================
# Proxy (Scraper)
# ================================
PB_PROXY_SERVER=
PB_PROXY_USERNAME=
PB_PROXY_PASSWORD=

# ================================
# App
# ================================
APP_ENV=development
APP_DEBUG=true
